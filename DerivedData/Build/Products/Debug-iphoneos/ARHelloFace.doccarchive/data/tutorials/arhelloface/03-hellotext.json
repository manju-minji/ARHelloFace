section","url":"\/tutorials\/arhelloface\/03-hellotext#%EC%96%BC%EA%B5%B4-%EC%9C%84%EC%97%90-%ED%85%8D%EC%8A%A4%ED%8A%B8-%EC%9C%84%EC%B9%98-%EC%9E%A1%EA%B8%B0","role":"pseudoSymbol"},"doc://arhelloface.ARHelloFace/tutorials/ARHelloFace/03-HelloText#%EC%99%84%EC%84%B1-%EC%BD%94%EB%93%9C-%ED%99%95%EC%9D%B8":{"identifier":"doc:\/\/arhelloface.ARHelloFace\/tutorials\/ARHelloFace\/03-HelloText#%EC%99%84%EC%84%B1-%EC%BD%94%EB%93%9C-%ED%99%95%EC%9D%B8","abstract":[{"text":"이제 얼굴 위에 “Hello” 텍스트를 3D로 표시합니다.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"SceneKit의 "},{"type":"codeVoice","code":"SCNText"},{"type":"text","text":"로 3D 텍스트 지오메트리를 만들고,"},{"text":" ","type":"text"},{"text":"얼굴 앵커 노드의 자식으로 추가해 얼굴을 따라다니게 합니다.","type":"text"}],"title":"완성 코드 확인","type":"section","kind":"section","url":"\/tutorials\/arhelloface\/03-hellotext#%EC%99%84%EC%84%B1-%EC%BD%94%EB%93%9C-%ED%99%95%EC%9D%B8","role":"pseudoSymbol"},"doc://arhelloface.ARHelloFace/tutorials/ARHelloFace/---------":{"identifier":"doc:\/\/arhelloface.ARHelloFace\/tutorials\/ARHelloFace\/---------","abstract":[],"type":"topic","title":"프로젝트 시작하기","kind":"article","url":"\/tutorials\/arhelloface\/---------","role":"article"},"s3-billboard.swift":{"identifier":"s3-billboard.swift","fileType":"swift","syntax":"swift","type":"file","content":["\/\/ s3-billboard.swift - Billboard Constraint 적용","private func makeHelloNode() -> SCNNode {","    let textGeometry = SCNText(string: \"Hello 👋\", extrusionDepth: 1.0)","    textGeometry.font = UIFont.systemFont(ofSize: 10, weight: .bold)","    let material = SCNMaterial()","    material.diffuse.contents = UIColor.white","    material.emission.contents = UIColor.white","    textGeometry.materials = [material]","","    let textNode = SCNNode(geometry: textGeometry)","    let scale: Float = 0.002","    textNode.scale = SCNVector3(scale, scale, scale)","","    let (min, max) = textNode.boundingBox","    let width = (max.x - min.x) * scale","    textNode.position = SCNVector3(-width \/ 2, 0.15, 0)","","    \/\/ 항상 카메라를 향하도록 - 얼굴이 옆을 봐도 텍스트는 정면 유지","    let billboard = SCNBillboardConstraint()","    billboard.freeAxes = .Y","    textNode.constraints = [billboard]","","    return textNode","}"],"fileName":"ViewController.swift","highlights":[{"line":1},{"line":17},{"line":18},{"line":19},{"line":20},{"line":21},{"line":22}]},"s3-text-position.swift":{"identifier":"s3-text-position.swift","fileType":"swift","syntax":"swift","type":"file","content":["\/\/ s3-text-position.swift - 얼굴 위 위치 설정","private func makeHelloNode() -> SCNNode {","    let textGeometry = SCNText(string: \"Hello 👋\", extrusionDepth: 1.0)","    textGeometry.font = UIFont.systemFont(ofSize: 10, weight: .bold)","    let material = SCNMaterial()","    material.diffuse.contents = UIColor.white","    material.emission.contents = UIColor.white","    textGeometry.materials = [material]","","    let textNode = SCNNode(geometry: textGeometry)","    let scale: Float = 0.002","    textNode.scale = SCNVector3(scale, scale, scale)","","    \/\/ 텍스트 가로 폭을 구해 중앙 정렬","    let (min, max) = textNode.boundingBox","    let width = (max.x - min.x) * scale","    \/\/ Y = 0.15 → 얼굴 앵커 원점에서 위로 15cm","    textNode.position = SCNVector3(-width \/ 2, 0.15, 0)","    return textNode","}"],"fileName":"ViewController.swift","highlights":[]},"s3-final.swift":{"fileType":"swift","identifier":"s3-final.swift","content":["\/\/ s3-final.swift - renderer(nodeFor:)에 Hello 노드 추가","func renderer(_ renderer: SCNSceneRenderer, nodeFor anchor: ARAnchor) -> SCNNode? {","    guard anchor is ARFaceAnchor else { return nil }","","    let faceNode = SCNNode()","    \/\/ makeHelloNode()를 자식으로 추가 → 얼굴을 따라 텍스트가 이동","    faceNode.addChildNode(makeHelloNode())","    return faceNode","}"],"type":"file","syntax":"swift","fileName":"ViewController.swift","highlights":[{"line":1},{"line":2},{"line":3},{"line":5},{"line":6},{"line":7},{"line":8}]},"doc://arhelloface.ARHelloFace/tutorials/ARHelloFace/02-FaceTracking":{"identifier":"doc:\/\/arhelloface.ARHelloFace\/tutorials\/ARHelloFace\/02-FaceTracking","abstract":[{"type":"text","text":"ARKit의 "},{"code":"ARFaceTrackingConfiguration","type":"codeVoice"},{"type":"text","text":"을 사용하면"},{"type":"text","text":" "},{"type":"text","text":"TrueDepth 카메라로 실시간 얼굴 위치, 방향, 표정 데이터를 얻을 수 있습니다."},{"text":" ","type":"text"},{"type":"text","text":"이 챕터에서는 AR 세션을 시작하고 "},{"code":"ARFaceAnchor","type":"codeVoice"},{"text":"를 감지합니다.","type":"text"}],"type":"topic","title":"ARFaceTrackingConfiguration으로 얼굴 인식","kind":"project","url":"\/tutorials\/arhelloface\/02-facetracking","role":"project","estimatedTime":"15min"},"s3-make-hello-node.swift":{"identifier":"s3-make-hello-node.swift","fileType":"swift","syntax":"swift","type":"file","content":["\/\/ s3-make-hello-node.swift","\/\/ makeHelloNode() 헬퍼 함수 - Step 1: SCNText 생성","","private func makeHelloNode() -> SCNNode {","    \/\/ SCNText 지오메트리 생성","    let textGeometry = SCNText(string: \"Hello 👋\", extrusionDepth: 1.0)","    textGeometry.font = UIFont.systemFont(ofSize: 10, weight: .bold)","    textGeometry.flatness = 0.1","","    let textNode = SCNNode(geometry: textGeometry)","    return textNode","}"],"fileName":"ViewController.swift","highlights":[]},"doc://arhelloface.ARHelloFace/tutorials/ARHelloFace/01-ProjectSetup#Xcode-%ED%94%84%EB%A1%9C%EC%A0%9D%ED%8A%B8-%EC%83%9D%EC%84%B1":{"identifier":"doc:\/\/arhelloface.ARHelloFace\/tutorials\/ARHelloFace\/01-ProjectSetup#Xcode-%ED%94%84%EB%A1%9C%EC%A0%9D%ED%8A%B8-%EC%83%9D%EC%84%B1","abstract":[{"type":"text","text":"ARKit Face Tracking을 사용하려면 TrueDepth 카메라를 지원하는"},{"type":"text","text":" "},{"type":"text","text":"기기(iPhone X 이상)가 필요합니다."},{"type":"text","text":" "},{"type":"text","text":"이 챕터에서는 Xcode 프로젝트를 만들고 ARSCNView를 화면에 배치합니다."}],"type":"section","title":"Xcode 프로젝트 생성","kind":"section","url":"\/tutorials\/arhelloface\/01-projectsetup#Xcode-%ED%94%84%EB%A1%9C%EC%A0%9D%ED%8A%B8-%EC%83%9D%EC%84%B1","role":"pseudoSymbol"}}}