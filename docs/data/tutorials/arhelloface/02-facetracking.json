":" "},{"type":"text","text":"SwiftUI 앱에서 "},{"code":"UIViewRepresentable","type":"codeVoice"},{"type":"text","text":"로 ARSCNView를 감싸 사용합니다."}],"role":"overview","type":"topic","title":"ARKit으로 Hello 띄우기"},"chapter2-intro.svg":{"identifier":"chapter2-intro.svg","alt":"ARFaceAnchor 감지 다이어그램","type":"image","variants":[{"traits":["1x","light"],"url":"\/images\/arhelloface.ARHelloFace\/chapter2-intro.svg","svgID":"bg"}]},"s2-did-update.swift":{"fileType":"swift","fileName":"ARFaceView.swift","type":"file","highlights":[{"line":1},{"line":2},{"line":3},{"line":4},{"line":5},{"line":6},{"line":8},{"line":9},{"line":10}],"syntax":"swift","content":["\/\/ s2-did-update.swift","\/\/ Coordinator 클래스 안에 추가하는 델리게이트 메서드입니다.","\/\/\/ ARKit이 매 프레임마다 앵커 transform을 자동으로 node에 동기화합니다.","\/\/\/ 추가 처리가 필요한 경우 이 메서드에서 구현합니다.","func renderer(_ renderer: SCNSceneRenderer, didUpdate node: SCNNode, for anchor: ARAnchor) {","    guard let faceAnchor = anchor as? ARFaceAnchor else { return }","","    \/\/ faceAnchor.blendShapes로 표정 데이터 접근 가능 (선택적 확장)","    \/\/ 예: let smileLeft = faceAnchor.blendShapes[.mouthSmileLeft]","    _ = faceAnchor  \/\/ 현재는 ARKit이 transform을 자동 처리하므로 추가 작업 불필요","}"],"identifier":"s2-did-update.swift"},"s2-run-session.swift":{"fileType":"swift","fileName":"ARFaceView.swift","type":"file","highlights":[],"syntax":"swift","content":["import SwiftUI","import ARKit","import SceneKit","","struct ARFaceView: UIViewRepresentable {","","    func makeUIView(context: Context) -> ARSCNView {","        let sceneView = ARSCNView()","        sceneView.showsStatistics = true","        sceneView.autoenablesDefaultLighting = true","","        \/\/ ARFaceTrackingConfiguration 생성 및 세션 시작","        let configuration = ARFaceTrackingConfiguration()","        configuration.isLightEstimationEnabled = true","        sceneView.session.run(configuration, options: [.resetTracking, .removeExistingAnchors])","","        return sceneView","    }","","    func updateUIView(_ uiView: ARSCNView, context: Context) {}","}"],"identifier":"s2-run-session.swift"},"doc://arhelloface.ARHelloFace/tutorials/ARHelloFace/02-FaceTracking#Coordinator%EB%A1%9C-%EC%96%BC%EA%B5%B4-%EC%95%B5%EC%BB%A4-%EC%B6%94%EC%A0%81":{"role":"pseudoSymbol","identifier":"doc:\/\/arhelloface.ARHelloFace\/tutorials\/ARHelloFace\/02-FaceTracking#Coordinator%EB%A1%9C-%EC%96%BC%EA%B5%B4-%EC%95%B5%EC%BB%A4-%EC%B6%94%EC%A0%81","type":"section","url":"\/tutorials\/arhelloface\/02-facetracking#Coordinator%EB%A1%9C-%EC%96%BC%EA%B5%B4-%EC%95%B5%EC%BB%A4-%EC%B6%94%EC%A0%81","title":"Coordinator로 얼굴 앵커 추적","abstract":[{"type":"text","text":"ARKit의 "},{"code":"ARFaceTrackingConfiguration","type":"codeVoice"},{"type":"text","text":"을 사용하면"},{"type":"text","text":" "},{"type":"text","text":"TrueDepth 카메라로 실시간 얼굴 위치, 방향, 표정 데이터를 얻을 수 있습니다."},{"type":"text","text":" "},{"type":"text","text":"이 챕터에서는 AR 세션을 시작하고, "},{"type":"codeVoice","code":"Coordinator"},{"type":"text","text":"로 "},{"type":"codeVoice","code":"ARFaceAnchor"},{"type":"text","text":"를 감지합니다."}],"kind":"section"},"doc://arhelloface.ARHelloFace/tutorials/ARHelloFace/03-HelloText":{"identifier":"doc:\/\/arhelloface.ARHelloFace\/tutorials\/ARHelloFace\/03-HelloText","estimatedTime":"15min","type":"topic","abstract":[{"type":"text","text":"이제 얼굴 위에 “Hello” 텍스트를 3D로 표시합니다."},{"type":"text","text":" "},{"type":"text","text":"SceneKit의 "},{"code":"SCNText","type":"codeVoice"},{"type":"text","text":"로 3D 텍스트 지오메트리를 만들고,"},{"type":"text","text":" "},{"type":"text","text":"얼굴 앵커 노드의 자식으로 추가해 얼굴을 따라다니게 합니다."},{"type":"text","text":" "},{"type":"text","text":"텍스트 생성 코드는 "},{"code":"Coordinator","type":"codeVoice"},{"type":"text","text":" 안에 작성합니다."}],"role":"project","kind":"project","title":"SCNText로 Hello 텍스트 띄우기","url":"\/tutorials\/arhelloface\/03-hellotext"},"s2-check-support.swift":{"fileType":"swift","fileName":"ContentView.swift","type":"file","highlights":[],"syntax":"swift","content":["import SwiftUI","import ARKit","","struct ContentView: View {","    var body: some View {","        \/\/ Face Tracking 지원 여부 확인 (TrueDepth 카메라 필요)","        if ARFaceTrackingConfiguration.isSupported {","            ARFaceView()","                .ignoresSafeArea()","        } else {","            \/\/ 미지원 기기 안내 화면 (UIAlertController 대신 SwiftUI 뷰로 표시)","            VStack(spacing: 12) {","                Image(systemName: \"faceid\")","                    .font(.system(size: 48))","                Text(\"미지원 기기\")","                    .font(.title2).bold()","                Text(\"Face Tracking은 TrueDepth 카메라가 있는\\n기기에서만 동작합니다.\")","                    .multilineTextAlignment(.center)","                    .foregroundStyle(.secondary)","            }","            .padding()","        }","    }","}"],"identifier":"s2-check-support.swift"},"doc://arhelloface.ARHelloFace/tutorials/ARHelloFace/01-ProjectSetup":{"identifier":"doc:\/\/arhelloface.ARHelloFace\/tutorials\/ARHelloFace\/01-ProjectSetup","estimatedTime":"10min","type":"topic","abstract":[{"type":"text","text":"ARKit Face Tracking을 사용하려면 TrueDepth 카메라를 지원하는"},{"type":"text","text":" "},{"type":"text","text":"기기(iPhone X 이상)가 필요합니다."},{"type":"text","text":" "},{"type":"text","text":"이 챕터에서는 SwiftUI 프로젝트를 만들고, UIKit 뷰인 "},{"code":"ARSCNView","type":"codeVoice"},{"type":"text","text":"를"},{"type":"text","text":" "},{"code":"UIViewRepresentable","type":"codeVoice"},{"type":"text","text":"로 감싸 화면에 배치합니다."}],"role":"project","kind":"project","title":"프로젝트 설정 및 ARSCNView를 SwiftUI로 감싸기","url":"\/tutorials\/arhelloface\/01-projectsetup"},"s2-session.svg":{"identifier":"s2-session.svg","alt":"AR 세션 흐름 다이어그램","type":"image","variants":[{"traits":["1x","light"],"url":"\/images\/arhelloface.ARHelloFace\/s2-session.svg","svgID":"bg"}]},"doc://arhelloface.ARHelloFace/tutorials/ARHelloFace/Hello---------":{"role":"article","identifier":"doc:\/\/arhelloface.ARHelloFace\/tutorials\/ARHelloFace\/Hello---------","type":"topic","url":"\/tutorials\/arhelloface\/hello---------","title":"Hello 텍스트 표시하기","kind":"article","abstract":[]},"s2-coordinator-adopt.swift":{"fileType":"swift","fileName":"ARFaceView.swift","type":"file","highlights":[],"syntax":"swift","content":["\/\/ s2-coordinator-adopt.swift","import SwiftUI","import ARKit","import SceneKit","","struct ARFaceView: UIViewRepresentable {","","    \/\/ Coordinator를 생성합니다. UIKit의 delegate 역할을 담당합니다.","    func makeCoordinator() -> Coordinator {","        Coordinator()","    }","","    func makeUIView(context: Context) -> ARSCNView {","        let sceneView = ARSCNView()","        sceneView.delegate = context.coordinator  \/\/ delegate 연결","        sceneView.showsStatistics = true","        sceneView.autoenablesDefaultLighting = true","","        let configuration = ARFaceTrackingConfiguration()","        configuration.isLightEstimationEnabled = true","        sceneView.session.run(configuration, options: [.resetTracking, .removeExistingAnchors])","        return sceneView","    }","","    func updateUIView(_ uiView: ARSCNView, context: Context) {}","","    \/\/ ARSCNViewDelegate를 채택하는 Coordinator","    \/\/ SwiftUI 구조체는 delegate가 될 수 없으므로 NSObject 클래스로 분리합니다.","    class Coordinator: NSObject, ARSCNViewDelegate {","    }","}"],"identifier":"s2-coordinator-adopt.swift"},"doc://arhelloface.ARHelloFace/tutorials/ARHelloFace/----------":{"role":"article","identifier":"doc:\/\/arhelloface.ARHelloFace\/tutorials\/ARHelloFace\/----------","url":"\/tutorials\/arhelloface\/----------","type":"topic","title":"얼굴 인식 구현하기","abstract":[],"kind":"article"},"doc://arhelloface.ARHelloFace/tutorials/ARHelloFace/01-ProjectSetup#ARSCNView%EB%A5%BC-UIViewRepresentable%EB%A1%9C-%EA%B0%90%EC%8B%B8%EA%B8%B0":{"role":"pseudoSymbol","identifier":"doc:\/\/arhelloface.ARHelloFace\/tutorials\/ARHelloFace\/01-ProjectSetup#ARSCNView%EB%A5%BC-UIViewRepresentable%EB%A1%9C-%EA%B0%90%EC%8B%B8%EA%B8%B0","url":"\/tutorials\/arhelloface\/01-projectsetup#ARSCNView%EB%A5%BC-UIViewRepresentable%EB%A1%9C-%EA%B0%90%EC%8B%B8%EA%B8%B0","ty