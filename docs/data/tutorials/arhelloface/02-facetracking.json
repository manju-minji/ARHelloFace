다."},{"type":"text","text":" "},{"type":"text","text":"이 챕터에서는 SwiftUI 프로젝트를 만들고, UIKit 뷰인 "},{"type":"codeVoice","code":"ARSCNView"},{"type":"text","text":"를"},{"type":"text","text":" "},{"type":"codeVoice","code":"UIViewRepresentable"},{"type":"text","text":"로 감싸 화면에 배치합니다."}],"kind":"section","type":"section","role":"pseudoSymbol","url":"\/tutorials\/arhelloface\/01-projectsetup#ARSCNView%EB%A5%BC-UIViewRepresentable%EB%A1%9C-%EA%B0%90%EC%8B%B8%EA%B8%B0","title":"ARSCNView를 UIViewRepresentable로 감싸기","identifier":"doc:\/\/arhelloface.ARHelloFace\/tutorials\/ARHelloFace\/01-ProjectSetup#ARSCNView%EB%A5%BC-UIViewRepresentable%EB%A1%9C-%EA%B0%90%EC%8B%B8%EA%B8%B0"},"doc://arhelloface.ARHelloFace/tutorials/ARHelloFace/---------":{"url":"\/tutorials\/arhelloface\/---------","kind":"article","type":"topic","role":"article","abstract":[],"title":"프로젝트 시작하기","identifier":"doc:\/\/arhelloface.ARHelloFace\/tutorials\/ARHelloFace\/---------"},"chapter2-intro.svg":{"type":"image","alt":"ARFaceAnchor 감지 다이어그램","variants":[{"url":"\/images\/arhelloface.ARHelloFace\/chapter2-intro.svg","svgID":"arrow","traits":["1x","light"]}],"identifier":"chapter2-intro.svg"},"s2-delegate.svg":{"type":"image","alt":"Coordinator delegate 흐름","variants":[{"url":"\/images\/arhelloface.ARHelloFace\/s2-delegate.svg","traits":["1x","light"],"svgID":"arrow"}],"identifier":"s2-delegate.svg"},"s2-coordinator-adopt.swift":{"fileName":"ARFaceView.swift","fileType":"swift","highlights":[],"type":"file","syntax":"swift","content":["\/\/ s2-coordinator-adopt.swift","import SwiftUI","import ARKit","import SceneKit","","struct ARFaceView: UIViewRepresentable {","","    \/\/ Coordinator를 생성합니다. UIKit의 delegate 역할을 담당합니다.","    func makeCoordinator() -> Coordinator {","        Coordinator()","    }","","    func makeUIView(context: Context) -> ARSCNView {","        let sceneView = ARSCNView()","        sceneView.delegate = context.coordinator  \/\/ delegate 연결","        sceneView.showsStatistics = true","        sceneView.autoenablesDefaultLighting = true","","        let configuration = ARFaceTrackingConfiguration()","        configuration.isLightEstimationEnabled = true","        sceneView.session.run(configuration, options: [.resetTracking, .removeExistingAnchors])","        return sceneView","    }","","    func updateUIView(_ uiView: ARSCNView, context: Context) {}","","    \/\/ ARSCNViewDelegate를 채택하는 Coordinator","    \/\/ SwiftUI 구조체는 delegate가 될 수 없으므로 NSObject 클래스로 분리합니다.","    class Coordinator: NSObject, ARSCNViewDelegate {","    }","}"],"identifier":"s2-coordinator-adopt.swift"},"doc://arhelloface.ARHelloFace/tutorials/ARHelloFace/----------":{"abstract":[],"kind":"article","type":"topic","role":"article","url":"\/tutorials\/arhelloface\/----------","title":"얼굴 인식 구현하기","identifier":"doc:\/\/arhelloface.ARHelloFace\/tutorials\/ARHelloFace\/----------"},"doc://arhelloface.ARHelloFace/tutorials/ARHelloFace/03-HelloText#%EC%96%BC%EA%B5%B4-%EC%9C%84%EC%97%90-%ED%85%8D%EC%8A%A4%ED%8A%B8-%EC%9C%84%EC%B9%98-%EC%9E%A1%EA%B8%B0":{"abstract":[{"type":"text","text":"이제 얼굴 위에 “Hello” 텍스트를 3D로 표시합니다."},{"type":"text","text":" "},{"type":"text","text":"SceneKit의 "},{"type":"codeVoice","code":"SCNText"},{"type":"text","text":"로 3D 텍스트 지오메트리를 만들고,"},{"text":" ","type":"text"},{"text":"얼굴 앵커 노드의 자식으로 추가해 얼굴을 따라다니게 합니다.","type":"text"},{"type":"text","text":" "},{"text":"텍스트 생성 코드는 ","type":"text"},{"type":"codeVoice","code":"Coordinator"},{"type":"text","text":" 안에 작성합니다."}],"kind":"section","type":"section","role":"pseudoSymbol","url":"\/tutorials\/arhelloface\/03-hellotext#%EC%96%BC%EA%B5%B4-%EC%9C%84%EC%97%90-%ED%85%8D%EC%8A%A4%ED%8A%B8-%EC%9C%84%EC%B9%98-%EC%9E%A1%EA%B8%B0","title":"얼굴 위에 텍스트 위치 잡기","identifier":"doc:\/\/arhelloface.ARHelloFace\/tutorials\/ARHelloFace\/03-HelloText#%EC%96%BC%EA%B5%B4-%EC%9C%84%EC%97%90-%ED%85%8D%EC%8A%A4%ED%8A%B8-%EC%9C%84%EC%B9%98-%EC%9E%A1%EA%B8%B0"}}}