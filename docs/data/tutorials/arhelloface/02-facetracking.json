de":"s2-did-update.swift","media":null,"type":"step","content":[{"inlineContent":[{"code":"renderer(_:didUpdate:for:)","type":"codeVoice"},{"type":"text","text":" 메서드로 매 프레임마다"},{"type":"text","text":" "},{"type":"text","text":"얼굴 위치를 업데이트합니다."},{"type":"text","text":" "},{"code":"ARFaceAnchor","type":"codeVoice"},{"type":"text","text":"의 "},{"type":"codeVoice","code":"transform"},{"text":"이 자동으로 노드에 적용됩니다.","type":"text"}],"type":"paragraph"}],"runtimePreview":null,"caption":[]}],"anchor":"ARSCNViewDelegate로-얼굴-앵커-추적"}],"kind":"tasks"},{"abstract":[{"text":"이제 얼굴 위에 “Hello” 텍스트를 3D로 표시합니다.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"SceneKit의 "},{"type":"codeVoice","code":"SCNText"},{"type":"text","text":"로 3D 텍스트 지오메트리를 만들고,"},{"text":" ","type":"text"},{"text":"얼굴 앵커 노드의 자식으로 추가해 얼굴을 따라다니게 합니다.","type":"text"}],"kind":"callToAction","featuredEyebrow":"Tutorial","title":"SCNText로 Hello 텍스트 띄우기","action":{"identifier":"doc:\/\/arhelloface.ARHelloFace\/tutorials\/ARHelloFace\/03-HelloText","overridingTitleInlineContent":[{"text":"Get started","type":"text"}],"overridingTitle":"Get started","type":"reference","isActive":true}}],"references":{"s2-did-update.swift":{"identifier":"s2-did-update.swift","fileType":"swift","syntax":"swift","type":"file","content":["\/\/ s2-did-update.swift","\/\/\/ ARKit이 매 프레임마다 앵커 transform을 자동으로 node에 동기화합니다.","\/\/\/ 추가 처리가 필요한 경우 이 메서드에서 구현합니다.","func renderer(_ renderer: SCNSceneRenderer, didUpdate node: SCNNode, for anchor: ARAnchor) {","    guard let faceAnchor = anchor as? ARFaceAnchor else { return }","","    \/\/ faceAnchor.blendShapes로 표정 데이터 접근 가능 (선택적 확장)","    \/\/ 예: let smileLeft = faceAnchor.blendShapes[.mouthSmileLeft]","    _ = faceAnchor  \/\/ 현재는 ARKit이 transform을 자동 처리하므로 추가 작업 불필요","}"],"fileName":"ViewController.swift","highlights":[{"line":1},{"line":2},{"line":3},{"line":4},{"line":5},{"line":7},{"line":8},{"line":9}]},"doc://arhelloface.ARHelloFace/tutorials/ARHelloFace/---------":{"identifier":"doc:\/\/arhelloface.ARHelloFace\/tutorials\/ARHelloFace\/---------","abstract":[],"type":"topic","title":"프로젝트 시작하기","kind":"article","url":"\/tutorials\/arhelloface\/---------","role":"article"},"doc://arhelloface.ARHelloFace/tutorials/ARHelloFace/Hello---------":{"identifier":"doc:\/\/arhelloface.ARHelloFace\/tutorials\/ARHelloFace\/Hello---------","abstract":[],"title":"Hello 텍스트 표시하기","type":"topic","kind":"article","url":"\/tutorials\/arhelloface\/hello---------","role":"article"},"s2-node-for-anchor.swift":{"identifier":"s2-node-for-anchor.swift","fileType":"swift","syntax":"swift","type":"file","content":["import UIKit","import ARKit","import SceneKit","","class ViewController: UIViewController, ARSCNViewDelegate {","","    @IBOutlet var sceneView: ARSCNView!","","    override func viewDidLoad() {","        super.viewDidLoad()","        sceneView.showsStatistics = true","        sceneView.autoenablesDefaultLighting = true","        \/\/ delegate 연결","        sceneView.delegate = self","    }","","    override func viewWillAppear(_ animated: Bool) {","        super.viewWillAppear(animated)","        guard ARFaceTrackingConfiguration.isSupported else { return }","        let configuration = ARFaceTrackingConfiguration()","        sceneView.session.run(configuration, options: [.resetTracking, .removeExistingAnchors])","    }","","    override func viewWillDisappear(_ animated: Bool) {","        super.viewWillDisappear(animated)","        sceneView.session.pause()","    }","","    \/\/ MARK: - ARSCNViewDelegate","","    \/\/\/ 새 앵커가 감지될 때 호출 - ARFaceAnchor이면 노드를 생성해 반환","    func renderer(_ renderer: SCNSceneRenderer, nodeFor anchor: ARAnchor) -> SCNNode? {","        guard anchor is ARFaceAnchor else { return nil }","","        let faceNode = SCNNode()","        \/\/ 다음 챕터에서 이 노드에 \"Hello\" 텍스트를 추가합니다","        return faceNode","    }","","    \/\/\/ 매 프레임마다 앵커 업데이트 - ARKit이 transform을 자동으로 동기화함","    func renderer(_ renderer: SCNSceneRenderer, didUpdate node: SCNNode, for anchor: ARAnchor) {","        guard anchor is ARFaceAnchor else { return }","        \/\/ ARKit이 node.transform을 ARFaceAnchor.transform과 자동 동기화합니다","    }","}"],"fileName":"ViewController.swift","highlights":[{"line":1},{"line":2},{"line":3},{"line":4},{"line":6},{"line":13},{"line":14},{"line":15},{"line":16},{"line":17},{"line":18},{"line":19},{"line":20},{"line":21},{"line":22},{"line":23},{"line":24},{"line":25},{"line":26},{"line":27},{"line":28},{"line":29},{"line":30},{"line":31},{"line":32},{"line":33},{"line":34},{"line":35},{"line":36},{"line":37},{"line":38},{"line":39},{"line":40},{"line":41},{"line":42},{"line":43}]},"doc://arhelloface.ARHelloFace/tutorials/ARHelloFace/02-FaceTracking#AR-%EC%84%B8%EC%85%98-%EC%8B%9C%EC%9E%91":{"identifier":"doc:\/\/arhelloface.ARHelloFace\/tutorials\/ARHelloFace\/02-FaceTracking#AR-%EC%84%B8%EC%85%98-%EC%8B%9C%EC%9E%91","abstract":[{"text":"ARKit의 ","type":"text"},{"type":"codeVoice","code":"ARFaceTrackingConfiguration"},{"type":"text","text":"을 사용하면"},{"type":"text","text":" "},{"type":"text","text":"TrueDepth 카메라로 실시간 얼굴 위치, 방향, 표정 데이터를 얻을 수 있습니다."},{"type":"text","text":" "},{"type":"text","text":"이 챕터에서는 AR 세션을 시작하고 "},{"type":"codeVoice","code":"ARFaceAnchor"},{"type":"text","text":"를 감지합니다."}],"type":"section","title":"AR 세션 시작","kind":"section","url":"\/tutorials\/arhelloface\/02-facetracking#AR-%EC%84%B8%EC%85%98-%EC%8B%9C%EC%9E%91","role":"pseudoSymbol"},"doc://arhelloface.ARHelloFace/tutorials/ARHelloFace/01-ProjectSetup#ARSCNView-%EC%B6%94%EA%B0%80":{"identifier":"doc:\/\/arhelloface.ARHelloFace\/tutorials\/ARHelloFace\/01-ProjectSetup#ARSCNView-%EC%B6%94%EA%B0%80","abstract":[{"type":"text","text":"ARKit Face Tracking을 사용하려면 TrueDepth 카메라를 지원하는"},{"type":"text","text":" "},{"type":"text","text":"기기(iPhone X 이상)가 필요합니다."},{"type":"text","text":" "},{"type":"text","text":"이 챕터에서는 Xcode 프로젝트를 만들고 ARSCNView를 화면에 배치합니다."}],"type":"section","title":"ARSCNView 추가","kind":"section","url":"\/tutorial