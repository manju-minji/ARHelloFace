":"s2-check-support.swift"},"doc://arhelloface.ARHelloFace/tutorials/ARHelloFace":{"identifier":"doc:\/\/arhelloface.ARHelloFace\/tutorials\/ARHelloFace","role":"overview","url":"\/tutorials\/arhelloface","title":"ARKit으로 Hello 띄우기","abstract":[{"type":"text","text":"ARKit의 Face Tracking 기능을 활용해 카메라로 사람 얼굴을 인식하고,"},{"type":"text","text":" "},{"type":"text","text":"머리 위에 “Hello” 텍스트를 증강현실로 표시하는 앱을 단계별로 만들어봅니다."},{"type":"text","text":" "},{"type":"text","text":"SwiftUI 앱에서 "},{"type":"codeVoice","code":"UIViewRepresentable"},{"type":"text","text":"로 ARSCNView를 감싸 사용합니다."}],"type":"topic","kind":"overview"},"s2-node-for-anchor.swift":{"fileName":"ARFaceView.swift","fileType":"swift","highlights":[{"line":13},{"line":25},{"line":26},{"line":27},{"line":28},{"line":29},{"line":30},{"line":32},{"line":33},{"line":34},{"line":35},{"line":36},{"line":37},{"line":38},{"line":39},{"line":40}],"type":"file","syntax":"swift","content":["import SwiftUI","import ARKit","import SceneKit","","struct ARFaceView: UIViewRepresentable {","","    func makeCoordinator() -> Coordinator {","        Coordinator()","    }","","    func makeUIView(context: Context) -> ARSCNView {","        let sceneView = ARSCNView()","        sceneView.delegate = context.coordinator","        sceneView.showsStatistics = true","        sceneView.autoenablesDefaultLighting = true","","        let configuration = ARFaceTrackingConfiguration()","        configuration.isLightEstimationEnabled = true","        sceneView.session.run(configuration, options: [.resetTracking, .removeExistingAnchors])","        return sceneView","    }","","    func updateUIView(_ uiView: ARSCNView, context: Context) {}","","    static func dismantleUIView(_ uiView: ARSCNView, coordinator: Coordinator) {","        uiView.session.pause()","    }","","    \/\/ MARK: - Coordinator (ARSCNViewDelegate)","","    class Coordinator: NSObject, ARSCNViewDelegate {","","        \/\/\/ 새 앵커가 감지될 때 호출 - ARFaceAnchor이면 노드를 생성해 반환","        func renderer(_ renderer: SCNSceneRenderer, nodeFor anchor: ARAnchor) -> SCNNode? {","            guard anchor is ARFaceAnchor else { return nil }","","            let faceNode = SCNNode()","            \/\/ 다음 챕터에서 이 노드에 \"Hello\" 텍스트를 추가합니다","            return faceNode","        }","    }","}"],"identifier":"s2-node-for-anchor.swift"},"doc://arhelloface.ARHelloFace/tutorials/ARHelloFace/01-ProjectSetup":{"identifier":"doc:\/\/arhelloface.ARHelloFace\/tutorials\/ARHelloFace\/01-ProjectSetup","role":"project","url":"\/tutorials\/arhelloface\/01-projectsetup","title":"프로젝트 설정 및 ARSCNView를 SwiftUI로 감싸기","abstract":[{"type":"text","text":"ARKit Face Tracking을 사용하려면 TrueDepth 카메라를 지원하는"},{"type":"text","text":" "},{"type":"text","text":"기기(iPhone X 이상)가 필요합니다."},{"type":"text","text":" "},{"type":"text","text":"이 챕터에서는 SwiftUI 프로젝트를 만들고, UIKit 뷰인 "},{"type":"codeVoice","code":"ARSCNView"},{"type":"text","text":"를"},{"type":"text","text":" "},{"type":"codeVoice","code":"UIViewRepresentable"},{"type":"text","text":"로 감싸 화면에 배치합니다."}],"type":"topic","estimatedTime":"10min","kind":"project"},"doc://arhelloface.ARHelloFace/tutorials/ARHelloFace/01-ProjectSetup#Xcode-%ED%94%84%EB%A1%9C%EC%A0%9D%ED%8A%B8-%EC%83%9D%EC%84%B1":{"abstract":[{"type":"text","text":"ARKit Face Tracking을 사용하려면 TrueDepth 카메라를 지원하는"},{"type":"text","text":" "},{"type":"text","text":"기기(iPhone X 이상)가 필요합니다."},{"type":"text","text":" "},{"type":"text","text":"이 챕터에서는 SwiftUI 프로젝트를 만들고, UIKit 뷰인 "},{"type":"codeVoice","code":"ARSCNView"},{"type":"text","text":"를"},{"type":"text","text":" "},{"type":"codeVoice","code":"UIViewRepresentable"},{"type":"text","text":"로 감싸 화면에 배치합니다."}],"kind":"section","type":"section","role":"pseudoSymbol","url":"\/tutorials\/arhelloface\/01-projectsetup#Xcode-%ED%94%84%EB%A1%9C%EC%A0%9D%ED%8A%B8-%EC%83%9D%EC%84%B1","title":"Xcode 프로젝트 생성","identifier":"doc:\/\/arhelloface.ARHelloFace\/tutorials\/ARHelloFace\/01-ProjectSetup#Xcode-%ED%94%84%EB%A1%9C%EC%A0%9D%ED%8A%B8-%EC%83%9D%EC%84%