ext":"AR 세션을 "},{"type":"codeVoice","code":"run(_:)"},{"text":"으로 시작합니다.","type":"text"}]}],"code":"s2-run-session.swift","caption":[],"type":"step","runtimePreview":null,"media":null}],"title":"AR 세션 시작","contentSection":[{"content":[{"type":"paragraph","inlineContent":[{"code":"ARFaceTrackingConfiguration","type":"codeVoice"},{"text":"은 전면 TrueDepth 카메라를 사용합니다.","type":"text"},{"text":" ","type":"text"},{"text":"기기가 Face Tracking을 지원하는지 반드시 먼저 확인해야 합니다.","type":"text"}]}],"mediaPosition":"trailing","kind":"contentAndMedia"}]},{"title":"Coordinator로 얼굴 앵커 추적","contentSection":[{"mediaPosition":"trailing","kind":"contentAndMedia","content":[{"type":"paragraph","inlineContent":[{"text":"SwiftUI 구조체는 값 타입이라 delegate가 될 수 없습니다.","type":"text"},{"type":"text","text":" "},{"code":"UIViewRepresentable","type":"codeVoice"},{"type":"text","text":"은 "},{"code":"Coordinator","type":"codeVoice"},{"type":"text","text":"라는 클래스를 두어"},{"type":"text","text":" "},{"type":"text","text":"UIKit의 delegate 패턴을 연결합니다."},{"type":"text","text":" "},{"type":"text","text":"여기서 "},{"code":"Coordinator","type":"codeVoice"},{"type":"text","text":"가 "},{"code":"ARSCNViewDelegate","type":"codeVoice"},{"type":"text","text":"를 채택합니다."}]}]}],"stepsSection":[{"caption":[],"code":"s2-coordinator-adopt.swift","runtimePreview":null,"type":"step","media":null,"content":[{"inlineContent":[{"type":"codeVoice","code":"makeCoordinator()"},{"type":"text","text":"로 "},{"code":"Coordinator","type":"codeVoice"},{"text":"를 생성하고,","type":"text"},{"text":" ","type":"text"},{"code":"makeUIView","type":"codeVoice"},{"text":"에서 ","type":"text"},{"code":"sceneView.delegate = context.coordinator","type":"codeVoice"},{"text":"로 연결합니다.","type":"text"},{"text":" ","type":"text"},{"code":"Coordinator","type":"codeVoice"},{"text":"는 ","type":"text"},{"code":"NSObject","type":"codeVoice"},{"text":"를 상속해 ","type":"text"},{"code":"ARSCNViewDelegate","type":"codeVoice"},{"text":"를 채택합니다.","type":"text"}],"type":"paragraph"}]},{"caption":[],"code":"s2-node-for-anchor.swift","runtimePreview":null,"type":"step","media":null,"content":[{"inlineContent":[{"code":"Coordinator","type":"codeVoice"},{"text":"에 ","type":"text"},{"code":"renderer(_:nodeFor:)","type":"codeVoice"},{"text":" 델리게이트 메서드를 구현합니다.","type":"text"},{"text":" ","type":"text"},{"text":"앵커가 ","type":"text"},{"code":"ARFaceAnchor","type":"codeVoice"},{"text":"인지 확인 후 빈 ","type":"text"},{"code":"SCNNode","type":"codeVoice"},{"text":"를 반환합니다.","type":"text"},{"text":" ","type":"text"},{"text":"다음 챕터에서 이 노드에 “Hello” 텍스트를 붙일 것입니다.","type":"text"}],"type":"paragraph"}]},{"caption":[],"code":"s2-did-update.swift","runtimePreview":null,"type":"step","media":null,"content":[{"inlineContent":[{"type":"codeVoice","code":"Coordinator"},{"type":"text","text":"에 "},{"type":"codeVoice","code":"renderer(_:didUpdate:for:)"},{"type":"text","text":" 메서드를 추가합니다."},{"type":"text","text":" "},{"type":"text","text":"매 프레임마다 호출되며, "},{"type":"codeVoice","code":"ARFaceAnchor"},{"type":"text","text":"의 "},{"type":"codeVoice","code":"transform"},{"type":"text","text":"이"},{"type":"text","text":" "},{"type":"text","text":"자동으로 노드에 적용됩니다."}],"type":"paragraph"}]},{"caption":[],"code":"s2-pause-session.swift","runtimePreview":null,"type":"step","media":null,"content":[{"inlineContent":[{"type":"text","text":"뷰가 사라질 때 AR 세션을 정리합니다."},{"type":"text","text":" "},{"type":"text","text":"UIKit의 "},{"type":"codeVoice","code":"viewWillDisappear"},{"type":"text","text":" 대신, "},{"type":"codeVoice","code":"UIViewRepresentable"},{"type":"text","text":"의"},{"type":"text","text":" "},{"type":"codeVoice","code":"dismantleUIView(_:coordinator:)"},{"type":"text","text":"에서 "},{"type":"codeVoice","code":"session.pause()"},{"type":"text","text":"를 호출합니다."}],"type":"paragraph"}]}],"anchor":"Coordinator로-얼굴-앵커-추적"}],"kind":"tasks"},{"abstract":[{"type":"text","text":"이제 얼굴 위에 “Hello” 텍스트를 3D로 표시합니다."},{"type":"text","text":" "},{"type":"text","text":"SceneKit의 "},{"code":"SCNText