":"NSObject","type":"codeVoice"},{"text":"를 상속해 ","type":"text"},{"code":"ARSCNViewDelegate","type":"codeVoice"},{"text":"를 채택합니다.","type":"text"}]}],"media":null,"caption":[],"code":"s2-coordinator-adopt.swift","runtimePreview":null,"type":"step"},{"content":[{"type":"paragraph","inlineContent":[{"code":"Coordinator","type":"codeVoice"},{"text":"에 ","type":"text"},{"code":"renderer(_:nodeFor:)","type":"codeVoice"},{"text":" 델리게이트 메서드를 구현합니다.","type":"text"},{"text":" ","type":"text"},{"text":"앵커가 ","type":"text"},{"code":"ARFaceAnchor","type":"codeVoice"},{"text":"인지 확인 후 빈 ","type":"text"},{"code":"SCNNode","type":"codeVoice"},{"text":"를 반환합니다.","type":"text"},{"text":" ","type":"text"},{"text":"다음 챕터에서 이 노드에 “Hello” 텍스트를 붙일 것입니다.","type":"text"}]}],"media":null,"caption":[],"code":"s2-node-for-anchor.swift","runtimePreview":null,"type":"step"},{"content":[{"type":"paragraph","inlineContent":[{"code":"Coordinator","type":"codeVoice"},{"text":"에 ","type":"text"},{"code":"renderer(_:didUpdate:for:)","type":"codeVoice"},{"text":" 메서드를 추가합니다.","type":"text"},{"text":" ","type":"text"},{"text":"매 프레임마다 호출되며, ","type":"text"},{"code":"ARFaceAnchor","type":"codeVoice"},{"text":"의 ","type":"text"},{"code":"transform","type":"codeVoice"},{"text":"이","type":"text"},{"type":"text","text":" "},{"text":"자동으로 노드에 적용됩니다.","type":"text"}]}],"media":null,"caption":[],"code":"s2-did-update.swift","runtimePreview":null,"type":"step"},{"code":"s2-pause-session.swift","caption":[],"type":"step","runtimePreview":null,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"뷰가 사라질 때 AR 세션을 정리합니다."},{"text":" ","type":"text"},{"type":"text","text":"UIKit의 "},{"type":"codeVoice","code":"viewWillDisappear"},{"type":"text","text":" 대신, "},{"type":"codeVoice","code":"UIViewRepresentable"},{"text":"의","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"dismantleUIView(_:coordinator:)"},{"text":"에서 ","type":"text"},{"type":"codeVoice","code":"session.pause()"},{