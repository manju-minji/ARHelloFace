oFace/Hello---------":{"identifier":"doc:\/\/arhelloface.ARHelloFace\/tutorials\/ARHelloFace\/Hello---------","role":"article","url":"\/tutorials\/arhelloface\/hello---------","abstract":[],"type":"topic","title":"Hello 텍스트 표시하기","kind":"article"},"doc://arhelloface.ARHelloFace/tutorials/ARHelloFace/02-FaceTracking#Coordinator%EB%A1%9C-%EC%96%BC%EA%B5%B4-%EC%95%B5%EC%BB%A4-%EC%B6%94%EC%A0%81":{"identifier":"doc:\/\/arhelloface.ARHelloFace\/tutorials\/ARHelloFace\/02-FaceTracking#Coordinator%EB%A1%9C-%EC%96%BC%EA%B5%B4-%EC%95%B5%EC%BB%A4-%EC%B6%94%EC%A0%81","role":"pseudoSymbol","url":"\/tutorials\/arhelloface\/02-facetracking#Coordinator%EB%A1%9C-%EC%96%BC%EA%B5%B4-%EC%95%B5%EC%BB%A4-%EC%B6%94%EC%A0%81","abstract":[{"text":"ARKit의 ","type":"text"},{"type":"codeVoice","code":"ARFaceTrackingConfiguration"},{"text":"을 사용하면","type":"text"},{"type":"text","text":" "},{"type":"text","text":"TrueDepth 카메라로 실시간 얼굴 위치, 방향, 표정 데이터를 얻을 수 있습니다."},{"type":"text","text":" "},{"type":"text","text":"이 챕터에서는 AR 세션을 시작하고, "},{"type":"codeVoice","code":"Coordinator"},{"type":"text","text":"로 "},{"type":"codeVoice","code":"ARFaceAnchor"},{"text":"를 감지합니다.","type":"text"}],"kind":"section","title":"Coordinator로 얼굴 앵커 추적","type":"section"},"s2-check-support.swift":{"fileType":"swift","content":["import SwiftUI","import ARKit","","struct ContentView: View {","    var body: some View {","        \/\/ Face Tracking 지원 여부 확인 (TrueDepth 카메라 필요)","        if ARFaceTrackingConfiguration.isSupported {","            ARFaceView()","                .ignoresSafeArea()","        } else {","            \/\/ 미지원 기기 안내 화면 (UIAlertController 대신 SwiftUI 뷰로 표시)","            VStack(spacing: 12) {","                Image(systemName: \"faceid\")","                    .font(.system(size: 48))","                Text(\"미지원 기기\")","                    .font(.title2).bold()","                Text(\"Face Tracking은 TrueDepth 카메라가 있는\\n기기에서만 동작합니다.\")","                    .multilineTextAlignment(.center)","                    .foregroundStyle(.secondary)","            }","            .padding()","        }","    }","}"],"syntax":"swift","identifier":"s2-check-support.swift","highlights":[],"type":"file","fileName":"ContentView.swift"},"s2-node-for-anchor.swift":{"fileType":"swift","content":["import SwiftUI","import ARKit","import SceneKit","","struct ARFaceView: UIViewRepresentable {","","    func makeCoordinator() -> Coordinator {","        Coordinator()","    }","","    func makeUIView(context: Context) -> ARSCNView {","        let sceneView = ARSCNView()","        sceneView.delegate = context.coordinator","        sceneView.showsStatistics = true","        sceneView.autoenablesDefaultLighting = true","","        let configuration = ARFaceTrackingConfiguration()","        configuration.isLightEstimationEnabled = true","        sceneView.session.run(configuration, options: [.resetTracking, .removeExistingAnchors])","        return sceneView","    }","","    func updateUIView(_ uiView: ARSCNView, context: Context) {}","","    static func dismantleUIView(_ uiView: ARSCNView, coordinator: Coordinator) {","        uiView.session.pause()","    }","","    \/\/ MARK: - Coordinator (ARSCNViewDelegate)","","    class Coordinator: NSObject, ARSCNViewDelegate {","","        \/\/\/ 새 앵커가 감지될 때 호출 - ARFaceAnchor이면 노드를 생성해 반환","        func renderer(_ renderer: SCNSceneRenderer, nodeFor anchor: ARAnchor) -> SCNNode? {","            guard anchor is ARFaceAnchor else { return nil }","","            let faceNode = SCNNode()","            \/\/ 다음 챕터에서 이 노드에 \"Hello\" 텍스트를 추가합니다","            return faceNode","        }","    }","}"],"syntax":"swift","identifier":"s2-node-for-anchor.swift","highlights":[{"line":13},{"line":25},{"line":26},{"line":27},{"line":28},{"line":29},{"line":30},{"line":32},{"line":33},{"line":34},{"line":35},{"line":36},{"line":37},{"line":38},{"line":39},{"line":40}],"type":"file","fileName":"ARFaceView.swift"},"s2-delegate.svg":{"variants":[{"traits":["1x","light"],"url":"\/images\/arhelloface.ARHelloFace\/s2-delegate.svg","svgID":"arrow"}],"alt":"Coordinator delegate 흐름","type":"image","identifier":"s2-delegate.svg"},"doc://arhelloface.ARHelloFace/tutorials/ARHelloFace/01-ProjectSetup#Xcode-%ED%94%84%EB%A1%9C%EC%A0%9D%ED%8A%B8-%EC%83%9D%EC%84%B1":{"identifier":"doc:\/\/arhelloface.ARHelloFace\/tutorials\/ARHelloFace\/01-ProjectSetup#Xcode-%ED%94%84%EB%A1%9C%EC%A0%9D%ED%8A%B8-%EC%83%9D%EC%84%B1","role":"pseudoSymbol","url":"\/tutorials\/arhelloface\/01-projectsetup#Xcode-%ED%94%84%EB%A1%9C%EC%A0%9D%ED%8A%B8-%EC%83%9D%EC%84%B1","abstract":[{"type":"text","text":"ARKit Face Tracking을 사용하려면 TrueDepth 카메라를 지원하는"},{"type":"text","text":" "},{"type":"text","text":"기기(iPhone X 이상)가 필요합니다."},{"type":"text","text":" "},{"type":"text","text":"이 챕터에서는 SwiftUI 프로젝트를 만들고, UIKit 뷰인 "},{"type":"codeVoice","code":"ARSCNView"},{"type":"text","text":"를"},{"type":"text","text":" "},{"type":"codeVoice","code":"UIViewRepresentable"},{"type":"text","text":"로 감싸 화면에 배치합니다."}],"type":"section","title":"Xcode 프로젝트 생성","kind":"section"},"doc://arhelloface.ARHelloFace/tutorials/ARHelloFace":{"type":"topic","abstract":[{"type":"text","text":"ARKit의 Face Tracking 기능을 활용해 카메라로 사람 얼굴을 인식하고,"},{"type":"text","text":" "},{"type":"text","text":"머리 위에 “Hello” 텍스트를 증강현실로 표시하는 앱을 단계별로 만들어봅니다."},{"type":"text","text":" "},{"type":"text","text":"SwiftUI 앱에서 "},{"type":"codeVoice","code":"UIViewRepresentable"},{"type":"text","text":"로 ARSCNView를 감싸 사용합니다."}],"role":"overview","kind":"overview","title":"ARKit으로 Hello 띄우기","url":"\/tutorials\/arhelloface","identifier":"doc:\/\/arhelloface.ARHelloFace\/tutorials\/ARHelloFace"},"doc://arhelloface.ARHelloFace/tutorials/ARHelloFace/02-FaceTracking#AR-%EC%84%B8%EC%85%98-%EC%8B%9C%EC%9E%91":{"kind":"section","role":"pseudoSymbol","title":"AR 세션 시작","identifier":"doc:\/\/arhelloface.ARHelloFace\/tutorials\/ARHelloFace\/02-FaceTracking#AR-%EC%84%B8%EC%85%98-%EC%8B%9C%EC%9E%91","abstract":[{"text":"ARKit의 ","type":"text"},{"code":"ARFaceTrackingConfiguration","type":"codeVoice"},{"text":"을 사용하면","type":"text"},{"text":" ","type":"text"},{"text":"TrueDepth 카메라로 실시간 얼굴 위치, 방향, 표정 데이터를 얻을 수 있습니다.","type":"text"},{"text":" ","type":"text"},{"text":"이 챕터에서는 AR 세션을 시작하고, ","type":"text"},{"type":"codeVoice","code":"Coordinator"},{"text":"로 ","type":"text"},{"type":"codeVoice","code":"ARFaceAnchor"},{"text":"를 감지합니다.","type":"text"}],"url":"\/tutorials\/arhelloface\/02-facetracking#AR-%EC%84%B8%EC%85%98-%EC%8B%9C%EC%9E%91","type":"section"},"doc://arhelloface.ARHelloFace/tutorials/ARHelloFace/01-ProjectSetup":{"type":"topic","abstract":[{"type":"text","text":"ARKit Face Tracking을 사용하려면 TrueDepth 카메라를 지원하는"},{"type":"text","text":" "},{"type":"text","text":"기기(iPhone X 이상)가 필요합니다."},{"type":"text","text":" "},{"type":"text","text":"이 챕터에서는 SwiftUI 프로젝트를 만들고, UIKit 뷰인 "},{"type":"codeVoice","code":"ARSCNView"},{"type":"text","text":"를"},{"type":"text","text":" "},{"type":"codeVoice","code":"UIViewRepresentable"},{"type":"text","text":"로 감싸 화면에 배치합니다."}],"role":"project","kind":"project","title":"프로젝트 설정 및 ARSCNView를 SwiftUI로 감싸기","estimatedTime":"10min","url":"\/tutorials\/arhelloface\/01-projectsetup","identifier":"doc:\/\/arhelloface.ARHelloFace\/tutorials\/ARHelloFace\/01-ProjectSetup"},"doc://arhelloface.ARHelloFace/tutorials/ARHelloFace/---------":{"kind":"article","role":"article","title":"프로젝트 시작하기","identifier":"doc:\/\/arhelloface.ARHelloFace\/tutorials\/ARHelloFace\/---------","abstract":[],"url":"\/tutorials\/arhelloface\/---------","type":"topic"},"doc://arhelloface.ARHelloFace/tutorials/ARHelloFace/01-ProjectSetup#ARSCNView%EB%A5%BC-UIViewRepresentable%EB%A1%9C-%EA%B0%90%EC%8B%B8%EA%B8%B0":{"kind":"section","role":"pseudoSymbol","title":"ARSCNView를 UIViewRepresentable로 감싸기","identifier":"doc:\/\/arhelloface.ARHelloFace\/tutorials\/ARHelloFace\/01-ProjectSetup#ARSCNView%EB%A5%BC-UIViewRepresentable%EB%A1%9C-%EA%B0%90%EC%8B%B8%EA%B8%B0","abstract":[{"type":"text","text":"ARKit Face Tracking을 사용하려면 TrueDepth 카메라를 지원하는"},{"type":"text","text":" "},{"type":"text","text":"기기(iPhone X 이상)가 필요합니다."},{"type":"text","text":" "},{"type":"text","text":"이 챕터에서는 SwiftUI 프로젝트를 만들고, UIKit 뷰인 "},{"type":"codeVoice","code":"ARSCNView"},{"type":"text","text":"를"},{"type":"text","text":" "},{"type":"codeVoice","code":"UIViewRepresentable"},{"type":"text","text":"로 감싸 화면에 배치합니다."}],"url":"\/tutorials\/arhelloface\/01-projectsetup#ARSCNView%EB%A5%BC-UIViewRepresentable%EB%A1%9C-%EA%B0%90%EC%8B%B8%EA%B8%B0","type":"section"},"s2-did-update.swift":{"fileType":"swift","syntax":"swift","content":["\/\/ s2-did-update.swift","\/\/ Coordinator 클래스 안에 추가하는 델리게이트 메서드입니다.","\/\/\/ ARKit이 매 프레임마다 앵커 transform을 자동으로 node에 동기화합니다.","\/\/\/ 추가 처리가 필요한 경우 이 메서드에서 구현합니다.","func renderer(_ renderer: SCNSceneRenderer, didUpdate node: SCNNode, for anchor: ARAnchor) {","    guard let faceAnchor = anchor as? ARFaceAnchor else { return }","","    \/\/ faceAnchor.blendShapes로 표정 데이터 접근 가능 (선택적 확장)","    \/\/ 예: let smileLeft = faceAnchor.blendShapes[.mouthSmileLeft]","    _ = faceAnchor  \/\/ 현재는 ARKit이 transform을 자동 처리하므로 추가 작업 불필요","}"],"identifier":"s2-did-update.swift","highlights":[{"line":1},{"line":2},{"line":3},{"line":4},{"line":5},{"line":6},{"line":8},{"line":9},{"line":10}],"type":"file","fileName":"ARFaceView.swift"},"s2-pause-session.swift":{"fileType":"swift","syntax":"swift","content":["\/\/ s2-pause-session.swift","\/\/ 뷰가 화면에서 사라지면 SwiftUI가 ARSCNView를 해제합니다.","\/\/ UIViewRepresentable의 dismantleUIView(_:coordinator:)에서 세션을 정리합니다.","\/\/ (UIKit의 viewWillDisappear에 해당하는 역할)","static func dismantleUIView(_ uiView: ARSCNView, coordinator: Coordinator) {","    \/\/ 화면 이탈 시 AR 세션 일시정지","    uiView.session.pause()","}"],"identifier":"s2-pause-session.swift","highlights":[{"line":1},{"line":2},{"line":3},{"line":4},{"line":5},{"line":6},{"line":7}],"type":"file","fileName":"ARFaceView.swift"}}}