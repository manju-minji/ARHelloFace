},"s3-scntext.svg":{"variants":[{"svgID":"bg","url":"\/images\/arhelloface.ARHelloFace\/s3-scntext.svg","traits":["1x","light"]}],"identifier":"s3-scntext.svg","type":"image","alt":"SCNText 속성 설명 다이어그램"},"s3-text-position.swift":{"highlights":[],"fileType":"swift","syntax":"swift","content":["\/\/ s3-text-position.swift - 얼굴 위 위치 설정","private func makeHelloNode() -> SCNNode {","    let textGeometry = SCNText(string: \"Hello 👋\", extrusionDepth: 1.0)","    textGeometry.font = UIFont.systemFont(ofSize: 10, weight: .bold)","    let material = SCNMaterial()","    material.diffuse.contents = UIColor.white","    material.emission.contents = UIColor.white","    textGeometry.materials = [material]","","    let textNode = SCNNode(geometry: textGeometry)","    let scale: Float = 0.002","    textNode.scale = SCNVector3(scale, scale, scale)","","    \/\/ 텍스트 가로 폭을 구해 중앙 정렬","    let (min, max) = textNode.boundingBox","    let width = (max.x - min.x) * scale","    \/\/ Y = 0.15 → 얼굴 앵커 원점에서 위로 15cm","    textNode.position = SCNVector3(-width \/ 2, 0.15, 0)","    return textNode","}"],"type":"file","fileName":"ARFaceView.swift","identifier":"s3-text-position.swift"},"s3-final.swift":{"highlights":[{"line":1},{"line":2},{"line":3},{"line":5},{"line":6},{"line":7},{"line":8}],"fileType":"swift","syntax":"swift","content":["\/\/ s3-final.swift - renderer(nodeFor:)에 Hello 노드 추가","func renderer(_ renderer: SCNSceneRenderer, nodeFor anchor: ARAnchor) -> SCNNode? {","    guard anchor is ARFaceAnchor else { return nil }","","    let faceNode = SCNNode()","    \/\/ makeHelloNode()를 자식으로 추가 → 얼굴을 따라 텍스트가 이동","    faceNode.addChildNode(makeHelloNode())","    return faceNode","}"],"type":"file","fileName":"ARFaceView.swift","identifier":"s3-final.swift"},"doc://arhelloface.ARHelloFace/tutorials/ARHelloFace/Hello---------":{"role":"article","identifier":"doc:\/\/arhelloface.ARHelloFace\/tutorials\/ARHelloFace\/Hello---------","type":"topic","url":"\/tutorials\/arhelloface\/hello---------","title":"Hello 텍스트 표시하기","kind":"article","abstract":[]},"s3-text-material.swift":{"highlights":[{"line":1},{"line":6},{"line":7},{"line":8},{"line":9},{"line":10},{"line":11}],"fileType":"swift","syntax":"swift","content":["\/\/ s3-text-material.swift - Step 2: 머티리얼 설정","private func makeHelloNode() -> SCNNode {","    let textGeometry = SCNText(string: \"Hello 👋\", extrusionDepth: 1.0)","    textGeometry.font = UIFont.systemFont(ofSize: 10, weight: .bold)","    textGeometry.flatness = 0.1","","    \/\/ 흰색 발광 머티리얼 - 조명에 상관없이 항상 밝게 보임","    let material = SCNMaterial()","    material.diffuse.contents = UIColor.white","    material.emission.contents = UIColor.white","    textGeometry.materials = [material]","","    let textNode = SCNNode(geometry: textGeometry)","    return textNode","}"],"type":"file","fileName":"ARFaceView.swift","identifier":"s3-text-material.swift"},"s3-coordinate.svg":{"variants":[{"svgID":"bg","url":"\/images\/arhelloface.ARHelloFace\/s3-coordinate.svg","traits":["1x","light"]}],"identifier":"s3-coordinate.svg","type":"image","alt":"ARKit 얼굴 좌표계 설명"},"doc://arhelloface.ARHelloFace/tutorials/ARHelloFace/01-ProjectSetup":{"identifier":"doc:\/\/arhelloface.ARHelloFace\/tutorials\/ARHelloFace\/01-ProjectSetup","estimatedTime":"10min","type":"topic","abstract":[{"type":"text","text":"ARKit Face Tracking을 사용하려면 TrueDepth 카메라를 지원하는"},{"type":"text","text":" "},{"type":"text","text":"기기(iPhone X 이상)가 필요합니다."},{"type":"text","text":" "},{"type":"text","text":"이 챕터에서는 SwiftUI 프로젝트를 만들고, UIKit 뷰인 "},{"code":"ARSCNView","type":"codeVoice"},{"type":"text","text":"를"},{"type":"text","text":" "},{"code":"UIViewRepresentable","type":"codeVoice"},{"type":"text","text":"로 감싸 화면에 배치합니다."}],"role":"project","kind":"project","title":"프로젝트 설정 및 ARSCNView를 SwiftUI로 감싸기","url":"\/tutorials\/arhelloface\/01-projectsetup"},"doc://arhelloface.ARHelloFace/tutorials/ARHelloFace/03-HelloText":{"identifier":"doc:\/\/arhelloface.ARHelloFace\/tutorials\/ARHelloFace\/03-HelloText",