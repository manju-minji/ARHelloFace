{"kind":"project","hierarchy":{"reference":"doc:\/\/arhelloface.ARHelloFace\/tutorials\/ARHelloFace","modules":[{"reference":"doc:\/\/arhelloface.ARHelloFace\/tutorials\/ARHelloFace\/---------","projects":[{"reference":"doc:\/\/arhelloface.ARHelloFace\/tutorials\/ARHelloFace\/01-ProjectSetup","sections":[{"reference":"doc:\/\/arhelloface.ARHelloFace\/tutorials\/ARHelloFace\/01-ProjectSetup#Xcode-%ED%94%84%EB%A1%9C%EC%A0%9D%ED%8A%B8-%EC%83%9D%EC%84%B1","kind":"task"},{"reference":"doc:\/\/arhelloface.ARHelloFace\/tutorials\/ARHelloFace\/01-ProjectSetup#ARSCNView%EB%A5%BC-UIViewRepresentable%EB%A1%9C-%EA%B0%90%EC%8B%B8%EA%B8%B0","kind":"task"}]}]},{"reference":"doc:\/\/arhelloface.ARHelloFace\/tutorials\/ARHelloFace\/----------","projects":[{"reference":"doc:\/\/arhelloface.ARHelloFace\/tutorials\/ARHelloFace\/02-FaceTracking","sections":[{"reference":"doc:\/\/arhelloface.ARHelloFace\/tutorials\/ARHelloFace\/02-FaceTracking#AR-%EC%84%B8%EC%85%98-%EC%8B%9C%EC%9E%91","kind":"task"},{"reference":"doc:\/\/arhelloface.ARHelloFace\/tutorials\/ARHelloFace\/02-FaceTracking#Coordinator%EB%A1%9C-%EC%96%BC%EA%B5%B4-%EC%95%B5%EC%BB%A4-%EC%B6%94%EC%A0%81","kind":"task"}]}]},{"reference":"doc:\/\/arhelloface.ARHelloFace\/tutorials\/ARHelloFace\/Hello---------","projects":[{"reference":"doc:\/\/arhelloface.ARHelloFace\/tutorials\/ARHelloFace\/03-HelloText","sections":[{"reference":"doc:\/\/arhelloface.ARHelloFace\/tutorials\/ARHelloFace\/03-HelloText#SCNText-%EB%85%B8%EB%93%9C-%EB%A7%8C%EB%93%A4%EA%B8%B0","kind":"task"},{"reference":"doc:\/\/arhelloface.ARHelloFace\/tutorials\/ARHelloFace\/03-HelloText#%EC%96%BC%EA%B5%B4-%EC%9C%84%EC%97%90-%ED%85%8D%EC%8A%A4%ED%8A%B8-%EC%9C%84%EC%B9%98-%EC%9E%A1%EA%B8%B0","kind":"task"},{"reference":"doc:\/\/arhelloface.ARHelloFace\/tutorials\/ARHelloFace\/03-HelloText#%EC%99%84%EC%84%B1-%EC%BD%94%EB%93%9C-%ED%99%95%EC%9D%B8","kind":"task"}]}]}],"paths":[["doc:\/\/arhelloface.ARHelloFace\/tutorials\/ARHelloFace","doc:\/\/arhelloface.ARHelloFace\/tut