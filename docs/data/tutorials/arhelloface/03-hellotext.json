type":"text"},{"text":" ","type":"text"},{"code":"makeHelloNode()","type":"codeVoice"},{"text":"를 자식으로 추가합니다.","type":"text"},{"text":" ","type":"text"},{"text":"이제 얼굴이 감지될 때마다 “Hello” 텍스트가 머리 위에 나타납니다.","type":"text"}],"type":"paragraph"}],"media":null,"code":"s3-final.swift"}],"anchor":"얼굴-위에-텍스트-위치-잡기"},{"anchor":"완성-코드-확인","title":"완성 코드 확인","contentSection":[{"mediaPosition":"trailing","content":[{"inlineContent":[{"type":"text","text":"모든 단계를 합친 최종 "},{"type":"codeVoice","code":"ARFaceView.swift"},{"type":"text","text":" 전체 코드입니다."},{"text":" ","type":"text"},{"code":"App","type":"codeVoice"},{"type":"text","text":" 진입점과 "},{"type":"codeVoice","code":"ContentView"},{"type":"text","text":", "},{"code":"ARFaceView","type":"codeVoice"},{"type":"text","text":"가 한 파일에 담겨 있습니다."},{"type":"text","text":" "},{"type":"text","text":"실제 기기(iPhone X 이상)에서 빌드해 테스트해보세요."}],"type":"paragraph"},{"style":"important","type":"aside","name":"Important","content":[{"type":"paragraph","inlineContent":[{"text":"ARKit Face Tracking은 시뮬레이터에서 동작하지 않습니다.","type":"text"},{"text":" ","type":"text"},{"text":"TrueDepth 카메라가 있는 실기기가 필요합니다.","type":"text"}]}]}],"kind":"contentAndMedia"}],"stepsSection":[{"media":null,"code":"s3-complete.swift","content":[{"inlineContent":[{"text":"완성된 전체 코드입니다. ","type":"text"},{"code":"App","type":"codeVoice"},{"text":" → ","type":"text"},{"code":"ContentView","type":"codeVoice"},{"text":" → ","type":"text"},{"code":"ARFaceView","type":"codeVoice"},{"text":" ","type":"text"},{"text":"(UIViewRepresentable) → ","type":"text"},{"code":"Coordinator","type":"codeVoice"},{"type":"text","text":" (ARSCNViewDelegate) 순으로"},{"type":"text","text":" "},{"text":"앞서 단계별로 작성한 모든 코드가 통합되어 있습니다.","type":"text"}],"type":"paragraph"}],"caption":[],"runtimePreview":null,"type":"step"}]}],"kind":"tasks"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/arhelloface.ARHelloFace\/tutorials\/ARHelloFace\/03-HelloText"},"references":{"doc://arhelloface.ARHelloFace/tutorials/ARHelloFace/01-ProjectSetup":{"kind":"project","title":"프로젝트 설정 및 ARSCNView를 SwiftUI로 감싸기","type":"topic","url":"\/tutorials\/arhelloface\/01-projectsetup","abstract":[{"text":"ARKit Face Tracking을 사용하려면 TrueDepth 카메라를 지원하는","type":"text"},{"text":" ","type":"text"},{"text":"기기(iPhone X 이상)가 필요합니다.","type":"text"},{"text":" ","type":"text"},{"text":"이 챕터에서는 SwiftUI 프로젝트를 만들고, UIKit 뷰인 ","type":"text"},{"code":"ARSCNView","type":"codeVoice"},{"text":"를","type":"text"},{"text":" ","type":"text"},{"code":"UIViewRepresentable","type":"codeVoice"},{"text":"로 감싸 화면에 배치합니다.","type":"text"}],"estimatedTime":"10min","identifier":"doc:\/\/arhelloface.ARHelloFace\/tutorials\/ARHelloFace\/01-ProjectSetup","role":"project"},"doc://arhelloface.ARHelloFace/tutorials/ARHelloFace/Hello---------":{"kind":"article","type":"topic","abstract":[],"url":"\/tutorials\/arhelloface\/hello---------","title":"Hello 텍스트 표시하기","role":"article","identifier":"doc:\/\/arhelloface.ARHelloFace\/tutorials\/ARHelloFace\/Hello---------"},"doc://arhelloface.ARHelloFace/tutorials/ARHelloFace/03-HelloText#SCNText-%EB%85%B8%EB%93%9C-%EB%A7%8C%EB%93%A4%EA%B8%B0":{"type":"section","kind":"section","role":"pseudoSymbol","url":"\/tutorials\/arhelloface\/03-hellotext#SCNText-%EB%85%B8%EB%93%9C-%EB%A7%8C%EB%93%A4%EA%B8%B0","abstract":[{"text":"이제 얼굴 위에 “Hello” 텍스트를 3D로 표시합니다.","type":"text"},{"text":" ","type":"text"},{"text":"SceneKit의 ","type":"text"},{"code":"SCNText","type":"codeVoice"},{"text":"로 3D 텍스트 지오메트리를 만들고,","type":"text"},{"text":" ","type":"text"},{"text":"얼굴 앵커 노드의 자식으로 추가해 얼굴을 따라다니게 합니다.","type":"text"},{"text":" ","type":"text"},{"text":"텍스트 생성 코드는 ","type":"text"},{"code":"Coordinator","type":"codeVoice"},{"text":" 안에 작성합니다.","type":"text"}],"title":"SCNText 노드 만들기","identifier":"doc:\/\/arhelloface.ARHelloFace\/tutorials\/ARHelloFace\/03-HelloText#SCNText-%EB%85%B8%EB%93%9C-%EB%A7%8C%EB%93%A4%EA%B8%B0"},"s3-final.swift":{"type":"file","syntax":"swift","identifier":"s3-final.swift","content":["\/\/ s3-final.swift - renderer(nodeFor:)에 Hello 노드 추가","func renderer(_ renderer: SCNSceneRenderer, nodeFor anchor: ARAnchor) -> SCNNode? {","    guard anchor is ARFaceAnchor else { return nil }","","    let faceNode = SCNNode()","    \/\/ makeHelloNode()를 자식으로 추가 → 얼굴을 따라 텍스트가 이동","    faceNode.addChildNode(makeHelloNode())","    return faceNode","}"],"fileName":"ARFaceView.swift","highlights":[{"line":1},{"line":2},{"line":3},{"line":5},{"line":6},{"line":7},{"line":8}],"fileType":"swift"},"doc://arhelloface.ARHelloFace/tutorials/ARHelloFace/02-FaceTracking#Coordinator%EB%A1%9C-%EC%96%BC%EA%B5%B4-%EC%95%B5%EC%BB%A4-%EC%B6%94%EC%A0%81":{"kind":"section","title":"Coordinator로 얼굴 앵커 추적","url":"\/tutorials\/arhelloface\/02-facetracking#Coordinator%EB%A1%9C-%EC%96%BC%EA%B5%B4-%EC%95%B5%EC%BB%A4-%EC%B6%94%EC%A0%81","abstract":[{"type":"text","text":"ARKit의 "},{"type":"codeVoice","code":"ARFaceTrackingConfiguration"},{"type":"text","text":"을 사용하면"},{"type":"text","text":" "},{"type":"text","text":"TrueDepth 카메라로 실시간 얼굴 위치, 방향, 표정 데이터를 얻을 수 있습니다."},{"type":"text","text":" "},{"type":"text","text":"이 챕터에서는 AR 세션을 시작하고, "},{"type":"codeVoice","code":"Coordinator"},{"type":"text","text":"로 "},{"type":"codeVoice","code":"ARFaceAnchor"},{"type":"text","text":"를 감지합니다."}],"type":"section","identifier":"doc:\/\/arhelloface.ARHelloFace\/tutorials\/ARHelloFace\/02-FaceTracking#Coordinator%EB%A1%9C-%EC%96%BC%EA%B5%B4-%EC%95%B5%EC%BB%A4-%EC%B6%94%EC%A0%81","role":"pseudoSymbol"},"s3-text-position.swift":{"type":"file","syntax":"swift","identifier":"s3-text-position.swift","content":["\/\/ s3-text-position.swift - 얼굴 위 위치 설정","private func makeHelloNode() -> SCNNode {","    let textGeometry = SCNText(string: \"Hello 👋\", extrusionDepth: 1.0)","    textGeometry.font = UIFont.systemFont(ofSize: 10, weight: .bold)","    let material = SCNMaterial()","    material.diffuse.contents = UIColor.white","    material.emission.contents = UIColor.white","    textGeometry.materials = [material]","","    let textNode = SCNNode(geometry: textGeometry)","    let scale: Float = 0.002","    textNode.scale = SCNVector3(scale, scale, scale)","","    \/\/ 텍스트 가로 폭을 구해 중앙 정렬","    let (min, max) = textNode.boundingBox","    let width = (max.x - min.x) * scale","    \/\/ Y = 0.15 → 얼굴 앵커 원점에서 위로 15cm","    textNode.position = SCNVector3(-width \/ 2, 0.15, 0)","    return textNode","}"],"fileName":"ARFaceView.swift","highlights":[],"fileType":"swift"},"s3-billboard.swift":{"type":"file","syntax":"swift","identifier":"s3-billboard.swift","content":["\/\/ s3-billboard.swift - Billboard Constraint 적용","private func makeHelloNode() -> SCNNode {","    let textGeometry = SCNText(string: \"Hello 👋\", extrusionDepth: 1.0)","    textGeometry.font = UIFont.systemFont(ofSize: 10, weight: .bold)","    let material = SCNMaterial()","    material.diffuse.contents = UIColor.white","    material.emission.contents = UIColor.white","    textGeometry.materials = [material]","","    let textNode = SCNNode(geometry: textGeometry)","    let scale: Float = 0.002","    textNode.scale = SCNVector3(scale, scale, scale)","","    let (min, max) = textNode.boundingBox","    let width = (max.x - min.x) * scale","    textNode.position = SCNVector3(-width \/ 2, 0.15, 0)","","    \/\/ 항상 카메라를 향하도록 - 얼굴이 옆을 봐도 텍스트는 정면 유지","    let billboard = SCNBillboardConstraint()","    billboard.freeAxes = .Y","    textNode.constraints = [billboard]","","    return textNode","}"],"fileName":"ARFaceView.swift","highlights":[{"line":1},{"line":17},{"line":18},{"line":19},{"line":20},{"line":21},{"line":22}],"fileType":"swift"},"doc://arhelloface.ARHelloFace/tutorials/ARHelloFace/01-ProjectSetup#ARSCNView%EB%A5%BC-UIViewRepresentable%EB%A1%9C-%EA%B0%90%EC%8B%B8%EA%B8%B0":{"kind":"section","type":"section","abstract":[{"text":"ARKit Face Tracking을 사용하려면 TrueDepth 카메라를 지원하는","type":"text"},{"text":" ","type":"text"},{"text":"기기(iPhone X 이상)가 필요합니다.","type":"text"},{"text":" ","type":"text"},{"text":"이 챕터에서는 SwiftUI 프로젝트를 만들고, UIKit 뷰인 ","type":"text"},{"type":"codeVoice","code":"ARSCNView"},{"text":"를","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"UIViewRepresentable"},{"type":"text","text":"로 감싸 화면에 배치합니다."}],"url":"\/tutorials\/arhelloface\/01-projectsetup#ARSCNView%EB%A5%BC-UIViewRepresentable%EB%A1%9C-%EA%B0%90%EC%8B%B8%EA%B8%B0","title":"ARSCNView를 UIViewRepresentable로 감싸기","role":"pseudoSymbol","identifier":"doc:\/\/arhelloface.ARHelloFace\/tutorials\/ARHelloFace\/01-ProjectSetup#ARSCNView%EB%A5%BC-UIViewRepresentable%EB%A1%9C-%EA%B0%90%EC%8B%B8%EA%B8%B0"},"s3-make-hello-node.swift":{"type":"file","syntax":"swift","identifier":"s3-make-hello-node.swift","content":["\/\/ s3-make-hello-node.swift","\/\/ makeHelloNode() 헬퍼 함수 - Step 1: SCNText 생성","","private func makeHelloNode() -> SCNNode {","    \/\/ SCNText 지오메트리 생성","    let textGeometry = SCNText(string: \"Hello 👋\", extrusionDepth: 1.0)","    textGeometry.font = UIFont.systemFont(ofSize: 10, weight: .bold)","    textGeometry.flatness = 0.1","","    let textNode = SCNNode(geometry: textGeometry)","    return textNode","}"],"fileName":"ARFaceView.swift","highlights":[],"fileType":"swift"},"s3-text-material.swift":{"type":"file","syntax":"swift","identifier":"s3-text-material.swift","content":["\/\/ s3-text-material.swift - Step 2: 머티리얼 설정","private func makeHelloNode() -> SCNNode {","    let textGeometry = SCNText(string: \"Hello 👋\", extrusionDepth: 1.0)","    textGeometry.font = UIFont.systemFont(ofSize: 10, weight: .bold)","    textGeometry.flatness = 0.1","","    \/\/ 흰색 발광 머티리얼 - 조명에 상관없이 항상 밝게 보임","    let material = SCNMaterial()","    material.diffuse.contents = UIColor.white","    material.emission.contents = UIColor.white","    textGeometry.materials = [material]","","    let textNode = SCNNode(geometry: textGeometry)","    return textNode","}"],"fileName":"ARFaceView.swift","highlights":[{"line":1},{"line":6},{"line":7},{"line":8},{"line":9},{"line":10},{"line":11}],"fileType":"swift"},"doc://arhelloface.ARHelloFace/tutorials/ARHelloFace/----------":{"kind":"article","type":"topic","abstract":[],"url":"\/tutorials\/arhelloface\/----------","title":"얼굴 인식 구현하기","role":"article","identifier":"doc:\/\/arhelloface.ARHelloFace\/tutorials\/ARHelloFace\/----------"},"doc://arhelloface.ARHelloFace/tutorials/ARHelloFace/---------":{"type":"topic","kind":"article","role":"article","url":"\/tutorials\/arhelloface\/---------","abstract":[],"title":"프로젝트 시작하기","identifier":"doc:\/\/arhelloface.ARHelloFace\/tutorials\/ARHelloFace\/---------"},"doc://arhelloface.ARHelloFace/tutorials/ARHelloFace/03-HelloText":{"kind":"project","type":"topic","abstract":[{"text":"이제 얼굴 위에 “Hello” 텍스트를 3D로 표시합니다.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"SceneKit의 "},{"code":"SCNText","type":"codeVoice"},{"type":"text","text":"로 3D 텍스트 지오메트리를 만들고,"},{"type":"text","text":" "},{"type":"text","text":"얼굴 앵커 노드의 자식으로 추가해 얼굴을 따라다니게 합니다."},{"type":"text","text":" "},{"type":"text","text":"텍스트 생성 코드는 "},{"code":"Coordinator","type":"codeVoice"},{"text":" 안에 작성합니다.","type":"text"}],"url":"\/tutorials\/arhelloface\/03-hellotext","estimatedTime":"15min","title":"SCNText로 Hello 텍스트 띄우기","role":"project","identifier":"doc:\/\/arhelloface.ARHelloFace\/tutorials\/ARHelloFace\/03-HelloText"},"s3-text-scale.swift":{"type":"file","syntax":"swift","identifier":"s3-text-scale.swift","content":["\/\/ s3-text-scale.swift - Step 3: 크기 조절","private func makeHelloNode() -> SCNNode {","    let textGeometry = SCNText(string: \"Hello 👋\", extrusionDepth: 1.0)","    textGeometry.font = UIFont.systemFont(ofSize: 10, weight: .bold)","    let material = SCNMaterial()","    material.diffuse.contents = UIColor.white","    material.emission.contents = UIColor.white","    textGeometry.materials = [material]","","    let textNode = SCNNode(geometry: textGeometry)","    \/\/ SCNText 기본 크기는 매우 크므로 0.002배로 축소 (약 2mm\/unit)","    let scale: Float = 0.002","    textNode.scale = SCNVector3(scale, scale, scale)","    return textNode","}"],"fileName":"ARFaceView.swift","highlights":[{"line":1},{"line":11},{"line":12},{"line":13}],"fileType":"swift"},"doc://arhelloface.ARHelloFace/tutorials/ARHelloFace/02-FaceTracking":{"kind":"project","type":"topic","abstract":[{"text":"ARKit의 ","type":"text"},{"code":"ARFaceTrackingConfiguration","type":"codeVoice"},{"text":"을 사용하면","type":"text"},{"text":" ","type":"text"},{"text":"TrueDepth 카메라로 실시간 얼굴 위치, 방향, 표정 데이터를 얻을 수 있습니다.","type":"text"},{"text":" ","type":"text"},{"text":"이 챕터에서는 AR 세션을 시작하고, ","type":"text"},{"code":"Coordinator","type":"codeVoice"},{"text":"로 ","type":"text"},{"code":"ARFaceAnchor","type":"codeVoice"},{"text":"를 감지합니다.","type":"text"}],"url":"\/tutorials\/arhelloface\/02-facetracking","estimatedTime":"15min","title":"ARFaceTrackingConfiguration으로 얼굴 인식","role":"project","identifier":"doc:\/\/arhelloface.ARHelloFace\/tutorials\/ARHelloFace\/02-FaceTracking"},"doc://arhelloface.ARHelloFace/tutorials/ARHelloFace/03-HelloText#%EC%96%BC%EA%B5%B4-%EC%9C%84%EC%97%90-%ED%85%8D%EC%8A%A4%ED%8A%B8-%EC%9C%84%EC%B9%98-%EC%9E%A1%EA%B8%B0":{"kind":"section","type":"section","abstract":[{"text":"이제 얼굴 위에 “Hello” 텍스트를 3D로 표시합니다.","type":"text"},{"text":" ","type":"text"},{"text":"SceneKit의 ","type":"text"},{"code":"SCNText","type":"codeVoice"},{"text":"로 3D 텍스트 지오메트리를 만들고,","type":"text"},{"text":" ","type":"text"},{"text":"얼굴 앵커 노드의 자식으로 추가해 얼굴을 따라다니게 합니다.","type":"text"},{"text":" ","type":"text"},{"text":"텍스트 생성 코드는 ","type":"text"},{"code":"Coordinator","type":"codeVoice"},{"text":" 안에 작성합니다.","type":"text"}],"url":"\/tutorials\/arhelloface\/03-hellotext#%EC%96%BC%EA%B5%B4-%EC%9C%84%EC%97%90-%ED%85%8D%EC%8A%A4%ED%8A%B8-%EC%9C%84%EC%B9%98-%EC%9E%A1%EA%B8%B0","title":"얼굴 위에 텍스트 위치 잡기","role":"pseudoSymbol","identifier":"doc:\/\/arhelloface.ARHelloFace\/tutorials\/ARHelloFace\/03-HelloText#%EC%96%BC%EA%B5%B4-%EC%9C%84%EC%97%90-%ED%85%8D%EC%8A%A4%ED%8A%B8-%EC%9C%84%EC%B9%98-%EC%9E%A1%EA%B8%B0"},"doc://arhelloface.ARHelloFace/tutorials/ARHelloFace":{"kind":"overview","title":"ARKit으로 Hello 띄우기","url":"\/tutorials\/arhelloface","abstract":[{"text":"ARKit의 Face Tracking 기능을 활용해 카메라로 사람 얼굴을 인식하고,","type":"text"},{"text":" ","type":"text"},{"text":"머리 위에 “Hello” 텍스트를 증강현실로 표시하는 앱을 단계별로 만들어봅니다.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"SwiftUI 앱에서 "},{"type":"codeVoice","code":"UIViewRepresentable"},{"type":"text","text":"로 ARSCNView를 감싸 사용합니다."}],"type":"topic","identifier":"doc:\/\/arhelloface.ARHelloFace\/tutorials\/ARHelloFace","role":"overview"},"s3-complete.swift":{"type":"file","syntax":"swift","identifier":"s3-complete.swift","content":["import SwiftUI","import ARKit","import SceneKit","import UIKit  \/\/ SceneKit 텍스트에 쓰는 UIColor \/ UIFont","","\/\/ MARK: - App 진입점","","@main","struct ARHelloFaceApp: App {","    var body: some Scene {","        WindowGroup {","            ContentView()","        }","    }","}","","\/\/ MARK: - ContentView","","struct ContentView: View {","    var body: some View {","        \/\/ Face Tracking 지원 기기에서만 AR 화면을 표시합니다.","        if ARFaceTrackingConfiguration.isSupported {","            ARFaceView()","                .ignoresSafeArea()","        } else {","            VStack(spacing: 12) {","                Image(systemName: \"faceid\")","                    .font(.system(size: 48))","                Text(\"미지원 기기\")","                    .font(.title2).bold()","                Text(\"Face Tracking은 TrueDepth 카메라가 있는\\niPhone X 이상에서만 동작합니다.\")","                    .multilineTextAlignment(.center)","                    .foregroundStyle(.secondary)","            }","            .padding()","        }","    }","}","","\/\/ MARK: - ARFaceView (UIViewRepresentable)","","\/\/\/ ARSCNView를 SwiftUI에서 사용할 수 있도록 감싼 래퍼입니다.","struct ARFaceView: UIViewRepresentable {","","    \/\/ delegate 역할을 할 Coordinator 생성","    func makeCoordinator() -> Coordinator {","        Coordinator()","    }","","    func makeUIView(context: Context) -> ARSCNView {","        let sceneView = ARSCNView()","        sceneView.delegate = context.coordinator","        sceneView.showsStatistics = true","        sceneView.autoenablesDefaultLighting = true","","        let configuration = ARFaceTrackingConfiguration()","        configuration.isLightEstimationEnabled = true","        sceneView.session.run(configuration, options: [.resetTracking, .removeExistingAnchors])","        return sceneView","    }","","    func updateUIView(_ uiView: ARSCNView, context: Context) {}","","    \/\/ 뷰가 제거될 때 AR 세션 일시정지 (UIKit의 viewWillDisappear 역할)","    static func dismantleUIView(_ uiView: ARSCNView, coordinator: Coordinator) {","        uiView.session.pause()","    }","","    \/\/ MARK: - Coordinator","","    \/\/\/ ARSCNViewDelegate를 구현해 얼굴 앵커에 노드를 붙입니다.","    class Coordinator: NSObject, ARSCNViewDelegate {","","        func renderer(_ renderer: SCNSceneRenderer, nodeFor anchor: ARAnchor) -> SCNNode? {","            guard anchor is ARFaceAnchor else { return nil }","","            let faceNode = SCNNode()","            faceNode.addChildNode(makeHelloNode())  \/\/ Hello 텍스트 노드를 자식으로 추가","            return faceNode","        }","","        func renderer(_ renderer: SCNSceneRenderer, didUpdate node: SCNNode, for anchor: ARAnchor) {","            guard anchor is ARFaceAnchor else { return }","            \/\/ ARKit이 node.transform을 ARFaceAnchor.transform과 자동 동기화합니다","        }","","        \/\/ MARK: - Hello Node 생성","","        \/\/\/ 얼굴 위에 표시할 \"Hello 👋\" 3D 텍스트 노드를 생성합니다.","        private func makeHelloNode() -> SCNNode {","            \/\/ 1. SCNText 지오메트리 생성","            let textGeometry = SCNText(string: \"Hello 👋\", extrusionDepth: 1.0)","            textGeometry.font = UIFont.systemFont(ofSize: 10, weight: .bold)","            textGeometry.flatness = 0.1  \/\/ 텍스트 곡선 부드럽기","","            \/\/ 2. 머티리얼 설정 - emission으로 조명과 무관하게 밝게 표시","            let material = SCNMaterial()","            material.diffuse.contents = UIColor.white","            material.emission.contents = UIColor.white","            textGeometry.materials = [material]","","            \/\/ 3. 텍스트 노드 생성 및 크기 조절","            let textNode = SCNNode(geometry: textGeometry)","            let scale: Float = 0.002","            textNode.scale = SCNVector3(scale, scale, scale)","","            \/\/ 4. 텍스트를 가로 중앙 정렬 (SCNText는 기본적으로 왼쪽 정렬)","            let (min, max) = textNode.boundingBox","            let width = (max.x - min.x) * scale","            textNode.position = SCNVector3(-width \/ 2, 0.15, 0)  \/\/ 얼굴 위 15cm","","            \/\/ 5. 항상 카메라를 바라보도록 Billboard Constraint 적용","            let billboard = SCNBillboardConstraint()","            billboard.freeAxes = .Y","            textNode.constraints = [billboard]","","            return textNode","        }","    }","}"],"fileName":"ARFaceView.swift","highlights":[],"fileType":"swift"},"doc://arhelloface.ARHelloFace/tutorials/ARHelloFace/03-HelloText#%EC%99%84%EC%84%B1-%EC%BD%94%EB%93%9C-%ED%99%95%EC%9D%B8":{"kind":"section","type":"section","abstract":[{"text":"이제 얼굴 위에 “Hello” 텍스트를 3D로 표시합니다.","type":"text"},{"text":" ","type":"text"},{"text":"SceneKit의 ","type":"text"},{"code":"SCNText","type":"codeVoice"},{"text":"로 3D 텍스트 지오메트리를 만들고,","type":"text"},{"text":" ","type":"text"},{"text":"얼굴 앵커 노드의 자식으로 추가해 얼굴을 따라다니게 합니다.","type":"text"},{"text":" ","type":"text"},{"text":"텍스트 생성 코드는 ","type":"text"},{"code":"Coordinator","type":"codeVoice"},{"text":" 안에 작성합니다.","type":"text"}],"url":"\/tutorials\/arhelloface\/03-hellotext#%EC%99%84%EC%84%B1-%EC%BD%94%EB%93%9C-%ED%99%95%EC%9D%B8","title":"완성 코드 확인","role":"pseudoSymbol","identifier":"doc:\/\/arhelloface.ARHelloFace\/tutorials\/ARHelloFace\/03-HelloText#%EC%99%84%EC%84%B1-%EC%BD%94%EB%93%9C-%ED%99%95%EC%9D%B8"},"doc://arhelloface.ARHelloFace/tutorials/ARHelloFace/01-ProjectSetup#Xcode-%ED%94%84%EB%A1%9C%EC%A0%9D%ED%8A%B8-%EC%83%9D%EC%84%B1":{"kind":"section","type":"section","abstract":[{"type":"text","text":"ARKit Face Tracking을 사용하려면 TrueDepth 카메라를 지원하는"},{"type":"text","text":" "},{"type":"text","text":"기기(iPhone X 이상)가 필요합니다."},{"type":"text","text":" "},{"type":"text","text":"이 챕터에서는 SwiftUI 프로젝트를 만들고, UIKit 뷰인 "},{"type":"codeVoice","code":"ARSCNView"},{"type":"text","text":"를"},{"type":"text","text":" "},{"type":"codeVoice","code":"UIViewRepresentable"},{"type":"text","text":"로 감싸 화면에 배치합니다."}],"url":"\/tutorials\/arhelloface\/01-projectsetup#Xcode-%ED%94%84%EB%A1%9C%EC%A0%9D%ED%8A%B8-%EC%83%9D%EC%84%B1","title":"Xcode 프로젝트 생성","role":"pseudoSymbol","identifier":"doc:\/\/arhelloface.ARHelloFace\/tutorials\/ARHelloFace\/01-ProjectSetup#Xcode-%ED%94%84%EB%A1%9C%EC%A0%9D%ED%8A%B8-%EC%83%9D%EC%84%B1"},"doc://arhelloface.ARHelloFace/tutorials/ARHelloFace/02-FaceTracking#AR-%EC%84%B8%EC%85%98-%EC%8B%9C%EC%9E%91":{"type":"section","kind":"section","role":"pseudoSymbol","url":"\/tutorials\/arhelloface\/02-facetracking#AR-%EC%84%B8%EC%85%98-%EC%8B%9C%EC%9E%91","abstract":[{"text":"ARKit의 ","type":"text"},{"type":"codeVoice","code":"ARFaceTrackingConfiguration"},{"text":"을 사용하면","type":"text"},{"text":" ","type":"text"},{"text":"TrueDepth 카메라로 실시간 얼굴 위치, 방향, 표정 데이터를 얻을 수 있습니다.","type":"text"},{"text":" ","type":"text"},{"text":"이 챕터에서는 AR 세션을 시작하고, ","type":"text"},{"type":"codeVoice","code":"Coordinator"},{"text":"로 ","type":"text"},{"code":"ARFaceAnchor","type":"codeVoice"},{"text":"를 감지합니다.","type":"text"}],"title":"AR 세션 시작","identifier":"doc:\/\/arhelloface.ARHelloFace\/tutorials\/ARHelloFace\/02-FaceTracking#AR-%EC%84%B8%EC%85%98-%EC%8B%9C%EC%9E%91"}}}